{% assign repository = include.repository | strip %}
{% assign repo_url = repository | split: '/' %}
{% assign repo_owner = repo_url[0] | strip %}
{% assign repo_name = repo_url[1] | strip %}
{% assign has_valid_repo = repo_url.size > 1 and repo_owner != '' and repo_name != '' %}
{% if site.data.repositories.github_users contains repo_owner %}
  {% assign show_owner = false %}
{% else %}
  {% assign show_owner = true %}
{% endif %}

{% assign meta = site.data.repositories.repo_details[repository] %}
{% capture tag_slugs %}
{% if meta and meta.tags %}{% for t in meta.tags %}{{ t | slugify }} {% endfor %}{% endif %}
{% endcapture %}

<div
  class="repo repo-showcase-card{% if meta and meta.featured %} repo-showcase-card--featured{% endif %}"
  data-repo-tags="{{ tag_slugs | strip }}"
>
  {% if has_valid_repo %}
    <div class="repo-card-inner card p-3 text-start h-100">
      <div class="d-flex flex-wrap align-items-start justify-content-between gap-2 mb-2">
        <h3 class="h5 mb-0 repo-showcase-title">
          <a href="https://github.com/{{ repository }}" target="_blank" rel="noopener noreferrer">
            {% if show_owner %}{{ repository }}{% else %}{{ repo_name }}{% endif %}
          </a>
        </h3>
        {% if meta and meta.status %}
          <span class="badge repo-status-badge rounded-pill">{{ meta.status }}</span>
        {% endif %}
      </div>

      {% if site.data.repositories.repo_summaries and site.data.repositories.repo_summaries[repository] %}
        <p class="mb-2 text-muted small repo-showcase-summary">{{ site.data.repositories.repo_summaries[repository] | strip }}</p>
      {% else %}
        <p class="mb-2 text-muted small">Open repository on GitHub.</p>
      {% endif %}

      {% if meta and meta.tags %}
        <div class="repo-tag-list mb-2">
          {% for t in meta.tags %}
            <span class="repo-tag-chip">{{ t }}</span>
          {% endfor %}
        </div>
      {% endif %}

      {% assign stats = site.data.repositories_stats.repos[repository] %}
      {% if stats and stats.error == nil %}
        {% if stats.language or stats.pushed_at or stats.stars %}
          <div class="repo-sync-meta mb-2 small text-muted">
            {% if stats.language %}
              <span class="repo-tag-chip repo-lang-chip" title="Primary language (from GitHub API)">{{ stats.language }}</span>
            {% endif %}
            {% if stats.pushed_at %}
              <span class="{% if stats.language %}ms-1{% endif %}">Last push {{ stats.pushed_at | date: '%Y-%m-%d' }}</span>
            {% endif %}
            {% if stats.stars != nil and stats.forks != nil %}
              <span class="ms-1 d-none d-md-inline text-nowrap">· {{ stats.stars }} stars · {{ stats.forks }} forks</span>
            {% endif %}
          </div>
        {% endif %}
      {% endif %}

      <div class="repo-badges mb-3 d-flex gap-2 flex-wrap align-items-center">
        <img
          alt="GitHub stars for {{ repository }}"
          loading="lazy"
          src="https://img.shields.io/github/stars/{{ repository }}?style=flat-square&label=stars"
        >
        <img
          alt="GitHub forks for {{ repository }}"
          loading="lazy"
          src="https://img.shields.io/github/forks/{{ repository }}?style=flat-square&label=forks"
        >
      </div>

      <div class="repo-actions d-flex flex-wrap gap-2">
        <a class="btn btn-sm btn-outline-primary" href="https://github.com/{{ repository }}" target="_blank" rel="noopener noreferrer">
          <i class="fa-brands fa-github" aria-hidden="true"></i> Code
        </a>
        {% if meta and meta.demo_url and meta.demo_url != '' %}
          <a class="btn btn-sm btn-outline-secondary" href="{{ meta.demo_url }}" target="_blank" rel="noopener noreferrer">Demo</a>
        {% endif %}
        {% if meta and meta.docs_url and meta.docs_url != '' %}
          <a class="btn btn-sm btn-outline-secondary" href="{{ meta.docs_url }}" target="_blank" rel="noopener noreferrer">Docs</a>
        {% endif %}
      </div>
    </div>
  {% else %}
    <div class="repo-card-inner card p-3 text-start">
      <p class="mb-2"><strong>{{ repository }}</strong></p>
      <p class="mb-0 text-muted">Invalid repository format. Use <code>owner/repository</code>.</p>
    </div>
  {% endif %}
</div>
